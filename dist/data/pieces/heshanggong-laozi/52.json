          "end": 5
        },
        "kind": "commentary",
        "text": "始有道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "道為天下萬物之母",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "子，一也。既知道己，當復知一也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "己知一，當復守道反無為也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "不危殆也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "兌，目也。目不妄視也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "門，口也。使口不妄言",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "人當塞目不妄視，閉口不妄言，則終生不勤苦。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "開目視情欲也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "濟，益也。益情欲之事。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "禍亂成也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 11,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "萌芽未動，禍亂未見為小，昭然獨見為明。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "守柔弱，日以強大也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 13,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "用其目光於外，視時世之利害。",
        "source": "cham"
      },
      {
        "id": "heshanggong-15",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 14,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "復當返其光明於內，無使精神泄也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-16",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 15,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "內視存神，不為漏失。",
        "source": "cham"
      },
      {
        "id": "heshanggong-17",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 16,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "人能行此，是謂修習常道。",
        "source": "cham"
      }
    ]
  },
