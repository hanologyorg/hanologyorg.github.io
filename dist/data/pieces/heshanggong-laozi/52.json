{
  "bookId": "heshanggong-laozi",
  "num": 52,
  "title": "第五十二章（歸元）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "天下有始，"
    },
    {
      "text": "以為天下母。"
    },
    {
      "text": "既知其母，復知其子，"
    },
    {
      "text": "既知其子，復守其母，"
    },
    {
      "text": "沒身不殆。"
    },
    {
      "text": "塞其兌，"
    },
    {
      "text": "閉其門，"
    },
    {
      "text": "終身不勤。"
    },
    {
      "text": "開其兌，"
    },
    {
      "text": "濟其事，"
    },
    {
      "text": "終身不救。"
    },
    {
      "text": "見小曰明，"
    },
    {
      "text": "守柔日強。"
    },
    {
      "text": "用其光，"
    },
    {
      "text": "復歸其明。"
    },
    {
      "text": "無遺身殃，"
    },
    {
      "text": "是謂習常。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
