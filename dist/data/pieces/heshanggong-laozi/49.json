          "end": 6
        },
        "kind": "commentary",
        "text": "百姓為善，聖人因而善之。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
