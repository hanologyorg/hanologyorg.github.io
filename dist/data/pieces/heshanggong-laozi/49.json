{
  "bookId": "heshanggong-laozi",
  "num": 49,
  "title": "第四十九章（任德）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "聖人無常心，"
    },
    {
      "text": "以百姓心為心。"
    },
    {
      "text": "善者吾善之，"
    },
    {
      "text": "不善者吾亦善之，"
    },
    {
      "text": "德善。"
    },
    {
      "text": "信者吾信之，"
    },
    {
      "text": "不信者吾亦信之，"
    },
    {
      "text": "德信。"
    },
    {
      "text": "聖人在天下怵怵，"
    },
    {
      "text": "為天下渾其心。"
    },
    {
      "text": "百姓皆注其耳目，"
    },
    {
      "text": "聖人皆孩之。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
