{
  "bookId": "heshanggong-laozi",
  "num": 14,
  "title": "第十四章（贊玄）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "視之不見名曰夷，"
    },
    {
      "text": "聽之不見名曰希，"
    },
    {
      "text": "搏之不得名曰微。"
    },
    {
      "text": "此三者不可致詰，"
    },
    {
      "text": "故混而為一。"
    },
    {
      "text": "其上不皦，"
    },
    {
      "text": "其下不昧。"
    },
    {
      "text": "繩繩不可名，"
    },
    {
      "text": "復歸於無物。"
    },
    {
      "text": "是謂無狀之狀，"
    },
    {
      "text": "無物之象，"
    },
    {
      "text": "是謂惚恍。"
    },
    {
      "text": "迎之不見其首，"
    },
    {
      "text": "隨之不見其後，"
    },
    {
      "text": "執古之道，以御今之有，"
    },
    {
      "text": "能知古始，是謂道紀。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
