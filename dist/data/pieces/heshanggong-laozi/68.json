{
  "bookId": "heshanggong-laozi",
  "num": 68,
  "title": "第六十八章（配天）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "善為士者不武，"
    },
    {
      "text": "善戰者不怒，"
    },
    {
      "text": "善勝敵者不與，"
    },
    {
      "text": "善用人者為之下。"
    },
    {
      "text": "是謂不爭之德，"
    },
    {
      "text": "是謂用人之力，"
    },
    {
      "text": "是謂配天古之極。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "言貴道德，不好武力也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "善以道戰者，禁邪於胸心，絕禍於未萌，無所誅怒也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "善以道勝敵者，附近以仁，來遠以德，不與敵爭，而敵自服也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "善用人自輔佐者，常為人執謙下也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "謂上為之下也。是乃不與人爭之道德也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "能身為人下，是謂用人臣之力也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "能行此者，德配天也。是乃古之極要道也。",
        "source": "cham"
      }
    ]
  },
