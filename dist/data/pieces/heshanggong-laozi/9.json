{
  "bookId": "heshanggong-laozi",
  "num": 9,
  "title": "第九章（運夷）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "持而盈之，不如其已。"
    },
    {
      "text": "揣而梲之，不可長保。"
    },
    {
      "text": "金玉滿堂，莫之能守。"
    },
    {
      "text": "富貴而驕，自遺其咎。"
    },
    {
      "text": "功成、名遂、身退，天之道。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "盈，滿也。已，止也。 持滿必傾，不如止也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "揣，治也。 先揣之，後必棄捐。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "嗜欲傷神，財多累身。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "夫富當賑貧，貴當憐賤，而反驕恣，必被禍患也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 13
        },
        "kind": "commentary",
        "text": "言人所為，功成事立，名跡稱遂，不退身避位，則遇於害，此乃天之常道也。譬如日中則移，月滿則虧，物盛則衰，樂極則哀。",
        "source": "cham"
      }
    ]
  },
