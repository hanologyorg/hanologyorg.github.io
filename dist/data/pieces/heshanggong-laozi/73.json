{
  "bookId": "heshanggong-laozi",
  "num": 73,
  "title": "第七十三章（任為）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "勇於敢則殺，"
    },
    {
      "text": "勇於不敢則活。"
    },
    {
      "text": "此兩者，"
    },
    {
      "text": "或利或害，"
    },
    {
      "text": "天之所惡。"
    },
    {
      "text": "孰知其故？"
    },
    {
      "text": "是以聖人猶難之。"
    },
    {
      "text": "天之道，不爭而善勝，"
    },
    {
      "text": "不言而善應，"
    },
    {
      "text": "不召而自來，"
    },
    {
      "text": "繟然而善謀。"
    },
    {
      "text": "天網恢恢，疏而不失。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
