{
  "bookId": "heshanggong-laozi",
  "num": 76,
  "title": "第七十六章（戒強）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "人之生也柔弱，"
    },
    {
      "text": "其死也堅強。"
    },
    {
      "text": "萬物草木之生也柔脆，"
    },
    {
      "text": "其死也枯槁。"
    },
    {
      "text": "故堅強者死之徒，柔弱者生之徒。"
    },
    {
      "text": "是以兵強則不勝，"
    },
    {
      "text": "木強則共。"
    },
    {
      "text": "強大處下，柔弱處上。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "人生含和氣，抱精神。故柔弱也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "人死和氣竭，精神亡，故堅強也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "和氣存也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "和氣去也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 15
        },
        "kind": "commentary",
        "text": "以上二事觀之，知堅強者死，柔弱者生也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "強大之兵輕戰樂殺，毒流怨結，眾弱為一強，故不勝。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "本強大則枝葉共生其上。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "興物造功，大木處下，小物處上。天道抑強扶弱，自然之效。",
        "source": "cham"
      }
    ]
  },
