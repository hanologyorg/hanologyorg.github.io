  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "信言不美，"
    },
    {
      "text": "美言不信。"
    },
    {
      "text": "善者不辯，辯者不善。知者不博，"
    },
    {
      "text": "博者不知。聖人不積，"
    },
    {
      "text": "既以為人己愈有，"
    },
    {
      "text": "既以與人己愈多。"
    },
    {
      "text": "天之道，利而不害；"
    },
    {
      "text": "聖人之道，為而不爭。"
    }
  ],
  "sections": {},
  "annotations": [],
