{
  "bookId": "laozi-wangbi-wiki",
  "num": 22,
  "title": "第二十二章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "曲則全，"
    },
    {
      "text": "枉則直，"
    },
    {
      "text": "窪則盈，"
    },
    {
      "text": "敝則新，"
    },
    {
      "text": "少則得，多則惑。"
    },
    {
      "text": "是以聖人抱一為天下式。"
    },
    {
      "text": "不自見故明，不自是故彰，不自伐故有功，不自矜故長。夫唯不爭，故天下莫能與之爭。古之所謂曲則全者，豈虛言哉！誠全而歸之。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不自見其明則全也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不自是則其是彰也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不自伐則其功有也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不自矜則其德長也。",
        "source": "cham"
      },
      {
        "id": "wangbi-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "自然之道亦猶樹也，轉多轉遠其根，轉少轉得其本。多則遠其真，故曰惑也；少則得其本，故曰得也。",
        "source": "cham"
      },
      {
        "id": "wangbi-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 11
        },
        "kind": "commentary",
        "text": "一，少之極也。式，猶則之也。",
        "source": "cham"
      }
    ]
  },
