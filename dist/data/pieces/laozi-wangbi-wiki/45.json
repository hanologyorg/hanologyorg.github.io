{
  "bookId": "laozi-wangbi-wiki",
  "num": 45,
  "title": "第四十五章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "大成若缺，其用不弊。"
    },
    {
      "text": "大盈若沖，其用不窮。"
    },
    {
      "text": "大直若屈，其用不居。"
    },
    {
      "text": "大巧若拙，其用不輟。"
    },
    {
      "text": "大辯若訥，其用不差。"
    },
    {
      "text": "躁勝寒，靜勝熱。清靜為天下正。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "隨物而成，不為一象，故若缺也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "大盈充足，隨物而與，無所愛矜，故若沖也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "隨物而直，直不在一，故若屈也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "大巧，因自然以成器，不造為異端，故若拙也。",
        "source": "cham"
      },
      {
        "id": "wangbi-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "大辯因物而言，己無所造，故若訥也。",
        "source": "cham"
      },
      {
        "id": "wangbi-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 15
        },
        "kind": "commentary",
        "text": "躁罷然後勝寒，靜無為以勝熱，以此推之，則清靜為天下正也。靜則全物之真，躁則犯物之性，故惟清靜，乃得如上諸大也。",
        "source": "cham"
      }
    ]
  },
