{
  "bookId": "laozi-wangbi-wiki",
  "num": 68,
  "title": "第六十八章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "善為士者不武，"
    },
    {
      "text": "善戰者不怒，"
    },
    {
      "text": "善勝敵者不與，"
    },
    {
      "text": "善用人者為之下，是謂不爭之德，是謂用人之力，"
    },
    {
      "text": "是謂配天古之極。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "士，卒之帥也。武，尚先陵人也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "後而不先，應而不唱，故不在怒。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "不與爭也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 22
        },
        "kind": "commentary",
        "text": "用人而不為之下，則力不為用也。",
        "source": "cham"
      }
    ]
  },
