  "num": 49,
  "title": "第四十九章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "聖人無常心，以百姓心為心。"
    },
    {
      "text": "善者，吾善之；不善者，吾亦善之，"
    },
    {
      "text": "德善。"
    },
    {
      "text": "信者，吾信之；不信者，吾亦信之，德信。聖人在天下歙歙，為天下渾其心，"
    },
    {
      "text": "百姓皆注其耳目,聖人皆孩之。"
    }
  ],
