  "num": 44,
  "title": "第四十四章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "名與身孰親？"
    },
    {
      "text": "身與貨孰多？"
    },
    {
      "text": "得與亡孰病？"
    },
    {
      "text": "是故甚愛必大費，多藏必厚亡，"
    },
    {
      "text": "知足不辱，知止不殆，可以長久。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "尚名好高，其身必疏。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "貪貨無厭，其身必少。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "得多利而亡其身，何者為病也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "甚愛不與物通，多藏不與物散，求之者多，攻之者眾，為物所病，故大費厚亡也。",
        "source": "cham"
      }
    ]
  },
