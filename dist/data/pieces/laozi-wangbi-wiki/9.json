{
  "bookId": "laozi-wangbi-wiki",
  "num": 9,
  "title": "第九章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "持而盈之，不如其已；"
    },
    {
      "text": "揣而梲之，不可長保。"
    },
    {
      "text": "金玉滿堂，莫之能守；"
    },
    {
      "text": "富貴而驕，自遺其咎。"
    },
    {
      "text": "功遂身退，天之道。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "持，謂不失德也。既不失其德又盈之，勢必傾危。故不如其已者，謂乃更不如無德無功者也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "既揣末令尖，又銳之令利，勢必摧衂，故不可長保也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "不若其已。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "不可長保也。",
        "source": "cham"
      },
      {
        "id": "wangbi-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "四時更運，功成則移。",
        "source": "cham"
      }
    ]
  },
