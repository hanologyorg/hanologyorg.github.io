  "genre": "prose",
  "verses": [
    {
      "text": "企者不立，"
    },
    {
      "text": "跨者不行，自見者不明，自是者不彰，自伐者無功，自矜者不長。其在道也，曰餘食贅行。"
    },
    {
      "text": "物或惡之，故有道者不處。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
