  "num": 79,
  "title": "第七十九章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "和大怨，必有餘怨，"
    },
    {
      "text": "安可以為善？是以聖人執左契，"
    },
    {
      "text": "而不責於人。有德司契，"
    },
    {
      "text": "無德司徹。"
    },
    {
      "text": "天道無親，常與善人。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "不明理其契，以致大怨已至。而德和之，其傷不復，故有餘怨也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "左契，防怨之所由生也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 11
        },
        "kind": "commentary",
        "text": "有德之人念思其契，不念怨生而後責於人也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "徹，司人之過也。",
        "source": "cham"
      }
    ]
  },
