  "verses": [
    {
      "text": "天下有道，卻走馬以糞。"
    },
    {
      "text": "天下無道，戎馬生於郊。"
    },
    {
      "text": "禍莫大於不知足；咎莫大於欲得。故知足之足，常足矣。"
    }
  ],
  "sections": {},
  "annotations": [],
