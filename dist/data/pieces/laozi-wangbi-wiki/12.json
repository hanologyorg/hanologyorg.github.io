{
  "bookId": "laozi-wangbi-wiki",
  "num": 12,
  "title": "第十二章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "五色令人目盲，五音令人耳聾，五味令人口爽，馳騁畋獵令人心發狂，"
    },
    {
      "text": "難得之貨令人行妨。"
    },
    {
      "text": "是以聖人為腹不為目，故去彼取此。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 31
        },
        "kind": "commentary",
        "text": "爽，差失也，失口之用，故謂之爽。夫耳目口心，皆順其性也，不以順性命，反以傷自然，故曰盲、聾、爽、狂也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "難得之貨，塞人正路，故令人行妨也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 16
        },
        "kind": "commentary",
        "text": "為腹者以物養己，為目者以物役己，故聖人不為目也。",
        "source": "cham"
      }
    ]
  },
