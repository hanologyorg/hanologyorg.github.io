  "genre": "prose",
  "verses": [
    {
      "text": "上善若水。水善利萬物而不爭，處眾人之所惡，"
    },
    {
      "text": "故幾於道。"
    },
    {
      "text": "居善地，心善淵，與善仁，言善信，正善治，事善能，動善時。夫唯不爭，故無尤。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 21
        },
        "kind": "commentary",
        "text": "人惡卑也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "道無水有，故曰，幾也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 37
        },
        "kind": "commentary",
        "text": "言人皆應於治道也。",
        "source": "cham"
      }
    ]
  },
