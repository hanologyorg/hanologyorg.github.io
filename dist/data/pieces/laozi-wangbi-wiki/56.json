{
  "bookId": "laozi-wangbi-wiki",
  "num": 56,
  "title": "第五十六章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "知者不言，"
    },
    {
      "text": "言者不知。"
    },
    {
      "text": "塞其兌，閉其門，挫其銳，"
    },
    {
      "text": "解其分，"
    },
    {
      "text": "和其光，"
    },
    {
      "text": "同其塵，"
    },
    {
      "text": "是謂玄同。故不可得而親，不可得而疏；"
    },
    {
      "text": "不可得而利，不可得而害；"
    },
    {
      "text": "不可得而貴，不可得而賤。"
    },
    {
      "text": "故為天下貴。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
