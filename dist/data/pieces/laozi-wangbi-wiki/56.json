          "end": 5
        },
        "kind": "commentary",
        "text": "因自然也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "造事端也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 12
        },
        "kind": "commentary",
        "text": "含守質也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "除爭原也。",
        "source": "cham"
      },
      {
        "id": "wangbi-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "無所特顯，則物無所偏爭也。",
        "source": "cham"
      },
      {
        "id": "wangbi-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "無所特賤，則物無所偏恥也。",
        "source": "cham"
      },
      {
        "id": "wangbi-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 18
        },
        "kind": "commentary",
        "text": "可得而親，則可得而疏也。",
        "source": "cham"
      },
      {
        "id": "wangbi-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 12
        },
        "kind": "commentary",
        "text": "可得而利，則可德而害也。",
        "source": "cham"
      },
      {
        "id": "wangbi-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 12
        },
        "kind": "commentary",
        "text": "可得而貴，則可得而賤也。",
        "source": "cham"
      },
      {
        "id": "wangbi-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "無物可以加之也。",
        "source": "cham"
      }
    ]
  },
