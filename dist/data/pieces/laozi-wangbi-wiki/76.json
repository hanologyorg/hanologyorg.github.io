          "verseIndex": 0,
          "start": 0,
          "end": 52
        },
        "kind": "commentary",
        "text": "强兵以暴於天下者，物之所惡也，故必不得勝。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "物所加也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "木之本也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
