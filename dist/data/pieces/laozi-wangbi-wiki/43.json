  "verses": [
    {
      "text": "天下之至柔，馳騁天下之至堅。"
    },
    {
      "text": "無有入無間，吾是以知無為之有益。"
    },
    {
      "text": "不言之教，無為之益，天下希及之。"
    }
  ],
