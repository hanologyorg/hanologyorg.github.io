{
  "bookId": "laozi-wangbi-wiki",
  "num": 80,
  "title": "第八十章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "小國寡民，"
    },
    {
      "text": "使有什伯之器而不用，"
    },
    {
      "text": "使民重死而不遠徙。"
    },
    {
      "text": "雖有舟輿，無所乘之；雖有甲兵，無所陳之。使人復結繩而用之，甘其食，美其服，安其居，樂其俗。鄰國相望，雞犬之聲相聞，民至老死，不相往來。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "國既小，民又寡，尚可使反古，況國大民眾乎？故舉小國而言也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "言使民雖有什伯之器而無所用，何患不足也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "使民不用，惟身是寶，不貪貨賂，故各安其居，重死而不遠徙也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 67
        },
        "kind": "commentary",
        "text": "無所欲求。",
        "source": "cham"
      }
    ]
  },
