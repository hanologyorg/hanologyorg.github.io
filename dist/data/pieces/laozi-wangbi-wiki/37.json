  "num": 37,
  "title": "第三十七章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "道常無為"
    },
    {
      "text": "而無不為。"
    },
    {
      "text": "侯王若能守之，萬物將自化。化而欲作，吾將鎮之以無名之樸。"
    },
    {
      "text": "無名之樸，夫亦將無欲。"
    },
    {
      "text": "不欲以靜，天下將自定。"
    }
  ],
