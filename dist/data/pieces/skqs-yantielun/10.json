          "end": 97
        },
        "kind": "semantic",
        "text": "去聲",
        "source": "cham"
      },
      {
        "id": "commentary-51",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 97,
          "end": 142
        },
        "kind": "semantic",
