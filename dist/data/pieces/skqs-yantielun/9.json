      {
        "id": "commentary-27",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 32,
          "end": 34
        },
        "kind": "semantic",
        "text": "老子曰兵者不祥之器不得已而用之韓非子曰夫戰者萬乘之存亡也且聞之曰削迹無遺根無與禍鄰禍乃不存尉繚子曰兵者凶器也爭者逆徳也事必有本故王者伐暴亂本仁義焉",
        "source": "cham"
      },
      {
        "id": "commentary-28",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 34,
          "end": 42
        },
        "kind": "semantic",
        "text": "音髙",
        "source": "cham"
      },
      {
        "id": "commentary-29",
