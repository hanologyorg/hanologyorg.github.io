{
  "bookId": "laozi-boshu",
  "num": 46,
  "title": "第四十六章（知足）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "天下有道 卻走馬以糞 天下无道 戎馬生於郊"
    },
    {
      "text": "罪莫大於可欲 禍莫大於不知足 咎莫憯於欲得"
    },
    {
      "text": "故知足之足 恆足矣"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "糞者，糞田也。兵甲不用，卻走馬治農田，治身者卻陽精以糞其身。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 11,
          "end": 12
        },
        "kind": "commentary",
        "text": "謂人主無道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 16,
          "end": 17
        },
        "kind": "commentary",
        "text": "戰伐不止，戎馬生於郊境之上，久不還也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "好淫色也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 7,
          "end": 8
        },
        "kind": "commentary",
        "text": "富貴不能自禁止也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 21
        },
        "kind": "commentary",
        "text": "欲得人物，利且貪也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "守真根也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 6,
          "end": 7
        },
        "kind": "commentary",
        "text": "無欲心也。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 11,
          "end": 12
        },
        "kind": "commentary",
        "text": "貪欲無厭，不修其內，各求於外，故戎馬生於郊也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
