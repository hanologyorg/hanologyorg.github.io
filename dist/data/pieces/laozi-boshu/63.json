{
  "bookId": "laozi-boshu",
  "num": 63,
  "title": "第六十三章（无難）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "為无為 事无事 味无味"
    },
    {
      "text": "大小多少 報怨以德"
    },
    {
      "text": "圖難乎亓易也 為大乎亓細也 天下之難作於易 天下之大作於細"
    },
    {
      "text": "是以聖人終不為大 故能成亓大"
    },
    {
      "text": "夫輕諾必寡信 多易必多難"
    },
    {
      "text": "是以聖人猶難之 故終於无難"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 4,
          "end": 5
        },
        "kind": "commentary",
        "text": "預有備，除煩省事也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 8,
          "end": 9
        },
        "kind": "commentary",
        "text": "深思遠慮，味道意也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "陳其戒令也。欲大反小，欲多反少，自然之道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "修道行善，絕禍於未生也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "欲圖難事，當於易時，未及成也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 29
        },
        "kind": "commentary",
        "text": "欲為大事，必作於小，禍亂從小來也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 29
        },
        "kind": "commentary",
        "text": "從易生難，從細生著。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "處謙虛，天下共歸之也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "不重言也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 7,
          "end": 8
        },
        "kind": "commentary",
        "text": "不慎患也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "聖人動作舉事，猶進退，重難之，欲塞其源也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 13
        },
        "kind": "commentary",
        "text": "聖人終生無患難之事，猶避害深也。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 11
        },
        "kind": "commentary",
        "text": "以無為為居，以不言為教，以恬淡為味，治之極也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "小怨則不足以報，大怨則天下之所欲誅，順天下之所同者，德也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "以聖人之才猶尚難於細易，況非聖人之才而欲忽於此乎，故曰，猶難之也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 13
        },
        "kind": "commentary",
        "text": "",
        "source": "cham"
      }
    ]
  },
