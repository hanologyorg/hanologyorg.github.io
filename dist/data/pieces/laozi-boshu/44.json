{
  "bookId": "laozi-boshu",
  "num": 44,
  "title": "第四十四章（立戒）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "名與身孰親？身與貨孰多？得與亡孰病？"
    },
    {
      "text": "甚愛必大費。多藏必厚亡。"
    },
    {
      "text": "故：知足不辱。知止不殆。可以長久。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 7,
          "end": 8
        },
        "kind": "commentary",
        "text": "財多則害身也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 14,
          "end": 15
        },
        "kind": "commentary",
        "text": "好得利則病於行也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 6,
          "end": 7
        },
        "kind": "commentary",
        "text": "甚愛色，費精神。甚愛財，遇禍患。所愛者少，所亡者多，故言大費。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 13,
          "end": 14
        },
        "kind": "commentary",
        "text": "生多藏於府庫，死多藏於丘墓。生有攻劫之憂，死有掘塚探柩之患。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 15,
          "end": 16
        },
        "kind": "commentary",
        "text": "知足之人絕利去欲，不辱於身。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 21,
          "end": 22
        },
        "kind": "commentary",
        "text": "知可止，則財利不累於身，聲色不亂於耳目，則身不危殆也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 27,
          "end": 28
        },
        "kind": "commentary",
        "text": "人能知止足則福祿在己，治身者，神不勞；治國者，民不擾，故可長久。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 7,
          "end": 8
        },
        "kind": "commentary",
        "text": "貪貨無厭，其身必少。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 14,
          "end": 15
        },
        "kind": "commentary",
        "text": "得多利而亡其身，何者為病也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 12,
          "end": 12
        },
        "kind": "commentary",
        "text": "甚愛不與物通，多藏不與物散，求之者多，攻之者眾，為物所病，故大費厚亡也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 15,
          "end": 16
        },
        "kind": "commentary",
        "text": "",
        "source": "cham"
      }
    ]
  },
