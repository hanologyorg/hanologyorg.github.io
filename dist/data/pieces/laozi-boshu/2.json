        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 43,
          "end": 43
        },
        "kind": "commentary",
        "text": "見高而為下也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 43,
          "end": 43
        },
        "kind": "commentary",
        "text": "上唱下必和也。",
        "source": "cham"
      },
      {
