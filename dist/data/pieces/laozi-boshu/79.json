{
  "bookId": "laozi-boshu",
  "num": 79,
  "title": "第七十九章（右介）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "和大怨 必有餘怨 焉可以為善"
    },
    {
      "text": "是以聖人執右介 而不以責於人"
    },
    {
      "text": "故有德司介 无德司徹"
    },
    {
      "text": "夫天道无親 恆與善人"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 4,
          "end": 5
        },
        "kind": "commentary",
        "text": "任刑者失人情，必有餘怨及於良人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "言一人吁嗟則失天心，安可以和怨為善？",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "古者聖人執左契，合符信也。無文書法律，刻契合符以為信也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "但刻契為信，不責人以他事也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "有德之君，司察契信而已。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 6,
          "end": 7
        },
        "kind": "commentary",
        "text": "無德之君，背其契信，司人所失。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 1,
          "end": 2
        },
        "kind": "commentary",
        "text": "天道無有親疏，唯與善人，則與司契者也。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "左契，防怨之所由生也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 14
        },
        "kind": "commentary",
        "text": "有德之人念思其契，不念怨生而後責於人也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 6,
          "end": 7
        },
        "kind": "commentary",
        "text": "徹，司人之過也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 1,
          "end": 2
        },
        "kind": "commentary",
        "text": "",
        "source": "cham"
      }
    ]
  },
