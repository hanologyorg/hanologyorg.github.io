{
  "bookId": "laozi-boshu",
  "num": 80,
  "title": "第八十章（安居）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "小邦寡民。"
    },
    {
      "text": "使十百人之器毋用。"
    },
    {
      "text": "使民重死而遠徙。"
    },
    {
      "text": "有車周无所乘之。"
    },
    {
      "text": "有甲兵无所陳之。"
    },
    {
      "text": "使民復結繩而用之。"
    },
    {
      "text": "甘亓食。"
    },
    {
      "text": "美亓服。"
    },
    {
      "text": "樂亓俗。"
    },
    {
      "text": "安亓居。"
    },
    {
      "text": "鄰邦相望。"
    },
    {
      "text": "雞狗之聲相聞。"
    },
    {
      "text": "民至老死，不相往來。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "聖人雖治大國，猶以為小，儉約不奢泰。民雖眾，猶若寡少，不敢勞之也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "使民各有部曲什伯，貴賤不相犯也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "器謂農，人之器而不用，不徵召奪民良時也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 10,
          "end": 11
        },
        "kind": "commentary",
        "text": "君能為民興利除害，各得其所，則民重死而貪生也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "政令不煩則民安其業，故不遠遷徙離其常處也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "清靜無為，不作煩華，不好出入遊娛也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "無怨惡於天下。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 37,
          "end": 38
        },
        "kind": "commentary",
        "text": "去文反質，信無欺也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "甘其蔬食，不漁食百姓也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "美其惡衣，不貴五色。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 15,
          "end": 16
        },
        "kind": "commentary",
        "text": "安其茅茨，不好文飾之屋。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 10,
          "end": 11
        },
        "kind": "commentary",
        "text": "樂其質樸之俗，不轉移也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 10,
          "end": 10
        },
        "kind": "commentary",
        "text": "相去近也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 14,
          "end": 15
        },
        "kind": "commentary",
        "text": "其無情欲。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "國既小，民又寡，尚可使反古，況國大民眾乎？故舉小國而言也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "言使民雖有什伯之器而無所用，何患不足也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 9,
          "end": 9
        },
        "kind": "commentary",
        "text": "使民不用，惟身是寶，不貪貨賂，故各安其居，重死而不遠徙也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 4,
          "end": 4
        },
        "kind": "commentary",
        "text": "無所欲求。",
        "source": "cham"
      }
    ]
  },
