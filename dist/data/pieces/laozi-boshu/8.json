{
  "bookId": "laozi-boshu",
  "num": 8,
  "title": "第八章（治水）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "上善治水 水善利萬物而有靜 居眾之所惡 故幾於道矣"
    },
    {
      "text": "居善地 心善淵 予善天 言善信 正善治 事善能 動善時"
    },
    {
      "text": "夫唯不爭 故无尤"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 25
        },
        "kind": "commentary",
        "text": "上善之人，如水之性。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 25
        },
        "kind": "commentary",
        "text": "水在天為霧露，在地為源泉也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 25
        },
        "kind": "commentary",
        "text": "眾人惡卑濕垢濁，水獨靜流居之也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 20,
          "end": 21
        },
        "kind": "commentary",
        "text": "水性幾於道同。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "水性善喜於地，草木之上即流而下，有似於牝動而下人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 4,
          "end": 5
        },
        "kind": "commentary",
        "text": "水深空虛，淵深清明。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 27
        },
        "kind": "commentary",
        "text": "萬物得水以生。與，虛不與盈也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 12,
          "end": 13
        },
        "kind": "commentary",
        "text": "水內影照形，不失其情也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 16,
          "end": 17
        },
        "kind": "commentary",
        "text": "無有不洗，清且平也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 20,
          "end": 21
        },
        "kind": "commentary",
        "text": "能方能圓，曲直隨形。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 24,
          "end": 25
        },
        "kind": "commentary",
        "text": "夏散冬凝，應期而動，不失天時。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "壅之則止，決之則流，聽從人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "水性如是，故天下無有怨尤水者也。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 25
        },
        "kind": "commentary",
        "text": "人惡卑也。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 20,
          "end": 21
        },
        "kind": "commentary",
        "text": "道無水有，故曰，幾也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 25
        },
        "kind": "commentary",
        "text": "言人皆應於治道也。",
        "source": "cham"
      }
    ]
  },
