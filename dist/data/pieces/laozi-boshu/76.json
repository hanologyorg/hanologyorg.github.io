{
  "bookId": "laozi-boshu",
  "num": 76,
  "title": "第七十六章（柔弱）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "人之生也柔弱，"
    },
    {
      "text": "亓死也恆仞堅強。"
    },
    {
      "text": "萬物草木之生也柔脆，"
    },
    {
      "text": "亓死也枯槁。"
    },
    {
      "text": "故曰："
    },
    {
      "text": "堅強者，死之徒也。"
    },
    {
      "text": "柔弱微細，生之徒也。"
    },
    {
      "text": "兵強則不勝。"
    },
    {
      "text": "木強則恆。"
    },
    {
      "text": "強大居下。"
    },
    {
      "text": "柔弱微細居上。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 6,
          "end": 6
        },
        "kind": "commentary",
        "text": "人死和氣竭，精神亡，故堅強也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 17,
          "end": 18
        },
        "kind": "commentary",
        "text": "和氣存也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 28,
          "end": 29
        },
        "kind": "commentary",
        "text": "和氣去也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 10,
          "end": 10
        },
        "kind": "commentary",
        "text": "以上二事觀之，知堅強者死，柔弱者生也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 5,
          "end": 5
        },
        "kind": "commentary",
        "text": "強大之兵輕戰樂殺，毒流怨結，眾弱為一強，故不勝。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 5,
          "end": 5
        },
        "kind": "commentary",
        "text": "本強大則枝葉共生其上。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 7,
          "end": 7
        },
        "kind": "commentary",
        "text": "興物造功，大木處下，小物處上。天道抑強扶弱，自然之效。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 5,
          "end": 5
        },
        "kind": "commentary",
        "text": "强兵以暴於天下者，物之所惡也，故必不得勝。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 5,
          "end": 5
        },
        "kind": "commentary",
        "text": "物所加也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "木之本也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 7,
          "end": 7
        },
        "kind": "commentary",
        "text": "枝條是也。",
        "source": "cham"
      }
    ]
  },
