      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "道為天下萬物之母。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 31,
          "end": 31
        },
        "kind": "commentary",
        "text": "子，一也。既知道己，當復知一也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 31,
          "end": 31
        },
        "kind": "commentary",
        "text": "己知一，當復守道反無為也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 27,
          "end": 28
        },
        "kind": "commentary",
        "text": "不危殆也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 21,
          "end": 22
        },
        "kind": "commentary",
        "text": "兌，目也。目不妄視也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 25,
          "end": 26
        },
        "kind": "commentary",
        "text": "門，口也。使口不妄言。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 13
        },
        "kind": "commentary",
        "text": "人當塞目不妄視，閉口不妄言，則終生不勤苦。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 13,
          "end": 26
        },
        "kind": "commentary",
        "text": "開目視情欲也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 4,
          "end": 5
        },
        "kind": "commentary",
        "text": "濟，益也。益情欲之事。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 13,
          "end": 26
        },
        "kind": "commentary",
        "text": "禍亂成也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 13,
          "end": 14
        },
        "kind": "commentary",
        "text": "萌芽未動，禍亂未見為小，昭然獨見為明。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 26,
          "end": 38
        },
        "kind": "commentary",
        "text": "守柔弱，日以強大也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 26,
          "end": 27
        },
        "kind": "commentary",
        "text": "用其目光於外，視時世之利害。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 30,
          "end": 31
        },
        "kind": "commentary",
        "text": "復當返其光明於內，無使精神洩也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-15",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 38,
          "end": 47
        },
        "kind": "commentary",
        "text": "內視存神，不為漏失。",
        "source": "cham"
      },
      {
        "id": "heshanggong-16",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 47,
          "end": 57
        },
        "kind": "commentary",
        "text": "人能行此，是謂修習常道。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 11
        },
        "kind": "commentary",
        "text": "善始之則善養畜之矣，故天下有始則可以為天下母矣。(按此段注文原脫，據樓宇烈補。)",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 31,
          "end": 31
        },
        "kind": "commentary",
        "text": "母，本也，子，末也。得本以知末，不舍本以逐末也。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 21,
          "end": 22
        },
        "kind": "commentary",
        "text": "兌，事欲之所由生；門，事欲之所由從也。",
        "source": "cham"
      },
      {
        "id": "wangbi-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 13
        },
        "kind": "commentary",
        "text": "無事永逸，故終身不勤也。",
        "source": "cham"
      },
      {
        "id": "wangbi-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 13,
          "end": 26
        },
        "kind": "commentary",
        "text": "不閉其原而濟其事，故雖終身不救。",
        "source": "cham"
      },
      {
        "id": "wangbi-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 26,
          "end": 38
        },
        "kind": "commentary",
        "text": "為治之功不在大，見大不明，見小乃明。守强不强，守柔乃强也。",
        "source": "cham"
      },
      {
        "id": "wangbi-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 26,
          "end": 27
        },
        "kind": "commentary",
        "text": "顯道以去民迷。",
        "source": "cham"
      },
      {
        "id": "wangbi-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 30,
          "end": 31
        },
        "kind": "commentary",
        "text": "不明察也。",
        "source": "cham"
      },
      {
        "id": "wangbi-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 38,
          "end": 47
        },
        "kind": "commentary",
        "text": "道之常也。",
        "source": "cham"
      }
    ]
