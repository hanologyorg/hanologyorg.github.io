{
  "bookId": "laozi-boshu",
  "num": 49,
  "title": "第四十九章（德善）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "聖人恆无心。"
    },
    {
      "text": "以百姓之心為心。"
    },
    {
      "text": "善者善之。"
    },
    {
      "text": "不善者亦善之。"
    },
    {
      "text": "德善也。"
    },
    {
      "text": "信者信之。"
    },
    {
      "text": "不信者亦信之。"
    },
    {
      "text": "德信也。"
    },
    {
      "text": "聖人之在天下，歙歙焉。"
    },
    {
      "text": "為天下渾心，百姓皆屬耳目焉。"
    },
    {
      "text": "聖人皆孩之。"
    }
  ],
