{
  "bookId": "laozi-boshu",
  "num": 19,
  "title": "第十九章（樸素）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "絕知棄辯 民利百倍"
    },
    {
      "text": "絕僞棄慮 民復孝茲"
    },
    {
      "text": "絕巧棄利 盜賊无有"
    },
    {
      "text": "此三言也 以為文未足 故令之有所屬"
    },
    {
      "text": "見素抱樸 少私寡欲 絕學无憂"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "絕聖制作，反初守元。五帝垂象，倉頡作書，不如三皇結繩無文。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "棄智慧，反無為。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "農事修，公無私。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "絕仁之見恩惠，棄義之尚華言。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "德化淳也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "絕巧者，詐偽亂真也。棄利者，塞貪路閉權門也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "上化公正，下無邪私。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "謂上三事所棄絕也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 17
        },
        "kind": "commentary",
        "text": "以為文不足者，文不足以教民。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 17
        },
        "kind": "commentary",
        "text": "當如下句。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 1
        },
        "kind": "commentary",
        "text": "見素者，當抱素守真，不尚文飾也。抱朴者，當抱其質樸，以示下，故可法則。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 5,
          "end": 6
        },
        "kind": "commentary",
        "text": "少私者，正無私也。寡欲者，當知足也。",
        "source": "cham"
      }
    ],
    "wangbi": [
      {
        "id": "wangbi-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "聖智，才之善也。仁義，人之善也。巧利，用之善也。而直云絕，文甚不足，不令之有所屬，無以見其指，故曰，此三者以為文而未足，故令人有所屬，屬之於素樸寡欲。",
        "source": "cham"
      }
    ]
  },
