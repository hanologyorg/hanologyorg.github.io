{
  "bookId": "laozi-heshanggong-wiki",
  "num": 3,
  "title": "第三章（安民）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "不尚賢，"
    },
    {
      "text": "使民不爭。"
    },
    {
      "text": "不貴難得之貨，"
    },
    {
      "text": "使民不為盜。"
    },
    {
      "text": "不見可慾，"
    },
    {
      "text": "使心不亂。"
    },
    {
      "text": "是以聖人之治，"
    },
    {
      "text": "虛其心，"
    },
    {
      "text": "實其腹，"
    },
    {
      "text": "弱其志，"
    },
    {
      "text": "強其骨。"
    },
    {
      "text": "常使民無知無慾。"
    },
    {
      "text": "使夫知者不敢為也。"
    },
    {
      "text": "為無為，"
    },
    {
      "text": "則無不治。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "賢謂世俗之賢，辯口明文，離道行權，去質為文也。不尚者，不貴之以祿，不貴之以官。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "不爭功名，返自然也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "言人君不御好珍寶，黃金棄於山，珠玉捐於淵也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "上化清靜，下無貪人。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "放鄭聲，遠美人。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "不邪淫，不惑亂也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "說聖人治國與治身同也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "除嗜欲，去亂煩。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "懷道抱一守，五神也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "和柔謙讓，不處權也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "愛精重施，髓滿骨堅。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 11,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "返樸守淳。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 0,
          "end": 9
        },
        "kind": "commentary",
        "text": "思慮深，不輕言。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 13,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不造作，動因循。",
        "source": "cham"
      },
      {
        "id": "heshanggong-15",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 14,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "德化厚，百姓安。",
        "source": "cham"
      }
    ]
  },
