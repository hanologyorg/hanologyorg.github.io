{
  "bookId": "laozi-heshanggong-wiki",
  "num": 24,
  "title": "第二十四章（苦恩）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "跂者不立，"
    },
    {
      "text": "跨者不行，"
    },
    {
      "text": "自見者不明，"
    },
    {
      "text": "自是者不彰，"
    },
    {
      "text": "自伐者無功，"
    },
    {
      "text": "自矜者不長。"
    },
    {
      "text": "其在道也，曰：餘食贅行。"
    },
    {
      "text": "物或惡之。"
    },
    {
      "text": "故有道者不處。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "跂，進也。謂貪權慕名，進取功榮，則不可久立身行道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "自以為貴而跨於人，眾共蔽之，使不得行。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "人自見其形容以為好，自見其所行以為應道，殊不知其形醜，操行之鄙。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "自以為是而非人，眾共蔽之，使不得彰明。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "所謂輒自伐取其功美，即失有功於人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "好自矜大者，不可以長久。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 12
        },
        "kind": "commentary",
        "text": "贅，貪也。使此自矜伐之人，在治國之道，日賦歛餘祿食以為貪行。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "此人在位，動欲傷害，故物無有不畏惡之者。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "言有道之人不居其國也。",
        "source": "cham"
      }
    ]
  },
