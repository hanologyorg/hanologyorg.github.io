{
  "bookId": "laozi-heshanggong-wiki",
  "num": 56,
  "title": "第五十六章（玄德）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "知者不言，"
    },
    {
      "text": "言者不知。"
    },
    {
      "text": "塞其兌，閉其門，"
    },
    {
      "text": "挫其銳，"
    },
    {
      "text": "解其紛，"
    },
    {
      "text": "和其光，"
    },
    {
      "text": "同其塵，"
    },
    {
      "text": "是謂玄同。"
    },
    {
      "text": "故不可得而親，"
    },
    {
      "text": "亦不可得而踈；"
    },
    {
      "text": "不可得而利，"
    },
    {
      "text": "亦不可得而害，"
    },
    {
      "text": "不可得而貴，"
    },
    {
      "text": "亦不可得而賤，"
    },
    {
      "text": "故為天下貴。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "知者貴行不貴言也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "駟不及舌，多言多患。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "塞閉之者，欲絕其源。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "情欲有所銳為，當念道無為以挫止之。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "紛，結恨不休也。當念道恬泊以解釋之。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "雖有獨見之明，當和之使闇昧，不使曜亂。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不當自別殊也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "玄，天也。人能行此上事，是謂與天同道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "不以榮譽為樂，獨立為哀。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "志靜無欲，故與人無怨。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "身不欲富貴，口不欲五味。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 11,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "不與貪爭利，不與勇爭氣。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "不為亂世主，不處暗君位。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 13,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "不以乘權故驕，不以失志故屈。",
        "source": "cham"
      },
      {
        "id": "heshanggong-15",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 14,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "其德如此，天子不得臣，諸侯不得屈，與世沉浮容身避害，故天下貴也。",
        "source": "cham"
      }
    ]
  },
