{
  "bookId": "laozi-heshanggong-wiki",
  "num": 12,
  "title": "第十二章（檢慾）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "五色令人目盲；"
    },
    {
      "text": "五音令人耳聾；"
    },
    {
      "text": "五味令人口爽；"
    },
    {
      "text": "馳騁畋獵，令人心發狂，"
    },
    {
      "text": "難得之貨，令人行妨。"
    },
    {
      "text": "是以聖人為腹，"
    },
    {
      "text": "不為目，"
    },
    {
      "text": "故去彼取此。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "貪淫好色，則傷精失明也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "好聽五音，則和氣去心，不能聽無聲之聲。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "爽，亡也。人嗜於五味於口，則口亡，言失於道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 11
        },
        "kind": "commentary",
        "text": "人精神好安靜，馳騁呼吸，精神散亡，故發狂也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "妨，傷也。難得之貨，謂金銀珠玉，心貪意欲，不知饜足，則行傷身辱也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "守五性，去六情，節志氣，養神明。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "目不妄視，妄視洩精於外。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "去彼目之妄視，取此腹之養性。",
        "source": "cham"
      }
    ]
  },
