{
  "bookId": "laozi-heshanggong-wiki",
  "num": 63,
  "title": "第六十三章（恩始）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "為無為，"
    },
    {
      "text": "事無事，"
    },
    {
      "text": "味無味。"
    },
    {
      "text": "大小多少，"
    },
    {
      "text": "報怨以德。"
    },
    {
      "text": "圖難於其易，"
    },
    {
      "text": "為大於其細。"
    },
    {
      "text": "天下難事必作於易，天下大事必作於細。"
    },
    {
      "text": "是以聖人終不為大，故能成其大。"
    },
    {
      "text": "夫輕諾必寡信，"
    },
    {
      "text": "多易必多難。"
    },
    {
      "text": "是以聖人猶難之，"
    },
    {
      "text": "故終無難矣。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "因成修故，無所造作。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "預有備，除煩省事也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "深思遠慮，味道意也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "陳其戒令也。欲大反小，欲多反少，自然之道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "修道行善，絕禍於未生也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "欲圖難事，當於易時，未及成也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "欲為大事，必作於小，禍亂從小來也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 18
        },
        "kind": "commentary",
        "text": "從易生難，從細生著。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 15
        },
        "kind": "commentary",
        "text": "處謙虛，天下共歸之也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "不重言也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "不慎患也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 11,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "聖人動作舉事，猶進退，重難之，欲塞其源也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "聖人終生無患難之事，猶避害深也。",
        "source": "cham"
      }
    ]
  },
