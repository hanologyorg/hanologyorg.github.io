{
  "bookId": "laozi-heshanggong-wiki",
  "num": 79,
  "title": "第七十九章（任契）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "和大怨，"
    },
    {
      "text": "必有餘怨，"
    },
    {
      "text": "安可以為善？"
    },
    {
      "text": "是以聖人執左契，"
    },
    {
      "text": "而不責於人。"
    },
    {
      "text": "有德司契，"
    },
    {
      "text": "無德司徹。"
    },
    {
      "text": "天道無親，常與善人。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "殺人者死，傷人者刑，以相和報。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "任刑者失人情，必有餘怨及於良人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "言一人吁嗟則失天心，安可以和怨為善？",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 8
        },
        "kind": "commentary",
        "text": "古者聖人執左契，合符信也。無文書法律，刻契合符以為信也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "但刻契為信，不責人以他事也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "有德之君，司察契信而已。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "無德之君，背其契信，司人所失。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "天道無有親疏，唯與善人，則與司契者也。",
        "source": "cham"
      }
    ]
  },
