        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "有功名也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "人所爭也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "見有而為無也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "見難而為易也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "見短而為長也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "見高而為下也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "上唱下必和也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "上行下必隨也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "以道治也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 11,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "以身師導之也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "各自動也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 13,
          "start": 0,
          "end": 4
        },
        "kind": "commentary",
        "text": "不辭謝而逆止。",
        "source": "cham"
      },
      {
        "id": "heshanggong-15",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 14,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "元氣生萬物而不有。",
        "source": "cham"
      },
      {
        "id": "heshanggong-16",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 15,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "道所施為，不恃望其報也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-17",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 16,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "功成事就，退避不居其位。",
        "source": "cham"
      },
      {
        "id": "heshanggong-18",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 17,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "夫惟功成不居其位。",
        "source": "cham"
      },
      {
        "id": "heshanggong-19",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 18,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "福德常在，不去其身也。此言不行不可隨，不言不可知疾。上六句有高下長短，君開一源，下生百端，百端之變，無不動亂。",
        "source": "cham"
      }
    ]
  },
