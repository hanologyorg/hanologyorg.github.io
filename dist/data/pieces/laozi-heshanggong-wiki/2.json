{
  "bookId": "laozi-heshanggong-wiki",
  "num": 2,
  "title": "第二章（養身）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "天下皆知美之為美，"
    },
    {
      "text": "斯惡已；"
    },
    {
      "text": "皆知善之為善，"
    },
    {
      "text": "斯不善已。"
    },
    {
      "text": "故有無相生，"
    },
    {
      "text": "難易相成，"
    },
    {
      "text": "長短相較，"
    },
    {
      "text": "高下相傾，"
    },
    {
      "text": "音聲相和，"
    },
    {
      "text": "前後相隨。"
    },
    {
      "text": "是以聖人處無為之事，"
    },
    {
      "text": "行不言之教，"
    },
    {
      "text": "萬物作焉，"
    },
    {
      "text": "而不辭，"
    },
    {
      "text": "生而不有，"
    },
    {
      "text": "為而不恃，"
    },
    {
      "text": "功成而弗居。"
    },
    {
      "text": "夫唯弗居，"
    },
    {
      "text": "是以不去。"
    }
  ],
  "sections": {},
  "annotations": [],
