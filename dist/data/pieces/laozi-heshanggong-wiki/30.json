{
  "bookId": "laozi-heshanggong-wiki",
  "num": 30,
  "title": "第三十章（儉武）",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "以道佐人主者，"
    },
    {
      "text": "不以兵強天下。"
    },
    {
      "text": "其事好還。"
    },
    {
      "text": "師之所處，荊棘生焉。"
    },
    {
      "text": "大軍之後，必有凶年。"
    },
    {
      "text": "善有果而已，"
    },
    {
      "text": "不敢以取強。"
    },
    {
      "text": "果而勿矜，"
    },
    {
      "text": "果而勿伐，"
    },
    {
      "text": "果而勿驕，"
    },
    {
      "text": "果而不得已，"
    },
    {
      "text": "果而勿強，"
    },
    {
      "text": "物壯則老，"
    },
    {
      "text": "是謂不道。"
    },
    {
      "text": "不道早已。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "heshanggong": [
      {
        "id": "heshanggong-1",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 0,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "謂人主能以道自輔佐也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 1,
          "start": 0,
          "end": 7
        },
        "kind": "commentary",
        "text": "以道自佐之主，不以兵革，順天任德，敵人自服。",
        "source": "cham"
      },
      {
        "id": "heshanggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "其舉事好還自責，不怨於人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-4",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "農事廢，田不修。",
        "source": "cham"
      },
      {
        "id": "heshanggong-5",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 4,
          "start": 0,
          "end": 10
        },
        "kind": "commentary",
        "text": "天應之以惡氣，即害五穀，盡傷人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-6",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "善用兵者，當果敢而已，不美之。",
        "source": "cham"
      },
      {
        "id": "heshanggong-7",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 6,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "不以果敢取強大之名也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-8",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 7,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "當果敢謙卑，勿自矜大也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-9",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 8,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "當果敢推讓，勿自伐取其美也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-10",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 9,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "驕，欺也。果敢勿以驕欺人。",
        "source": "cham"
      },
      {
        "id": "heshanggong-11",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 10,
          "start": 0,
          "end": 6
        },
        "kind": "commentary",
        "text": "當果敢至誠，不當逼迫不得已也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-12",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 11,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "果敢勿以為強兵、堅甲以欺凌人也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-13",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 12,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "草木壯極則枯落，人壯極則衰老也。言強者不可以久。",
        "source": "cham"
      },
      {
        "id": "heshanggong-14",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 13,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "枯老者，坐不行道也。",
        "source": "cham"
      },
      {
        "id": "heshanggong-15",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 14,
          "start": 0,
          "end": 5
        },
        "kind": "commentary",
        "text": "不行道者早死。",
        "source": "cham"
      }
    ]
  },
