  "verses": [
    {
      "text": "谷神不死，是謂玄牝。"
    },
    {
      "text": "玄牝之門，是謂天地根。"
    },
    {
      "text": "綿綿呵若存，用之不勤。"
    }
  ],
  "sections": {},
