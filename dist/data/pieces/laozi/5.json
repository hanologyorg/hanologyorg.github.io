  "genre": "prose",
  "verses": [
    {
      "text": "天地不仁，以萬物為芻狗。"
    },
    {
      "text": "聖人不仁，以百姓為芻狗。"
    },
    {
      "text": "天地之間，其猶橐籥與？"
    },
    {
      "text": "虛而不屈，動而愈出。"
    },
    {
      "text": "多言數窮，不如守中。"
    }
  ],
  "sections": {},
  "annotations": [],
