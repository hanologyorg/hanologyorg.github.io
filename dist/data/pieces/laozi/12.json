  "genre": "prose",
  "verses": [
    {
      "text": "五色令人目盲，五音令人耳聾，五味令人口爽，"
    },
    {
      "text": "馳騁畋獵令人心發狂，難得之貨令人行妨。"
    },
    {
      "text": "是以聖人為腹不為目，故去彼取此。"
    }
  ],
  "sections": {},
  "annotations": [],
