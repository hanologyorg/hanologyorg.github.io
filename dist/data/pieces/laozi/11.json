  "bookId": "laozi",
  "num": 11,
  "title": "第十一章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "三十輻共一轂，當其無，有車之用。"
    },
    {
      "text": "埏埴以為器，當其無，有器之用。"
    },
    {
      "text": "鑿戶牖以為室，當其無，有室之用。"
    },
    {
      "text": "故有之以為利，無之以為用。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
