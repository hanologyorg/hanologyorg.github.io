  "verses": [
    {
      "text": "企者不立，跨者不行。自見者不明，自是者不彰。"
    },
    {
      "text": "自伐者無功，自矜者不長。其在道也，曰餘食贅行。"
    },
    {
      "text": "物或惡之，故有道者不處。"
    }
  ],
