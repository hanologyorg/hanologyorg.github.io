{
  "bookId": "laozi",
  "num": 3,
  "title": "第三章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "不上賢，使民不爭。"
    },
    {
      "text": "不貴難得之貨，使民不為盜。"
    },
    {
      "text": "不見可欲，使民心不亂。"
    },
    {
      "text": "是以聖人之治也，虛其心，實其腹，弱其志，強其骨，"
    },
    {
      "text": "恆使民無知無欲也。"
    },
    {
      "text": "使夫知不敢弗為而已，則無不治矣。"
    }
  ],
  "sections": {},
  "annotations": [],
