  "verses": [
    {
      "text": "載營魄抱一，能無離乎？"
    },
    {
      "text": "專氣致柔，能嬰兒乎？"
    },
    {
      "text": "滌除玄覽，能無疵乎？"
    },
    {
      "text": "愛民治國，能無為乎？"
    },
    {
      "text": "天門開闔，能為雌乎？"
    },
    {
      "text": "明白四達，能無知乎？"
    }
  ],
