  "title": "第四章",
  "author": "老子",
  "authorId": "Laozi",
  "dynasty": "周",
  "era": "周",
  "genre": "prose",
  "verses": [
    {
      "text": "道沖，而用之有弗盈也。"
    },
    {
      "text": "淵呵！似萬物之宗。"
    },
    {
      "text": "銼其銳，解其紛，和其光，同其塵。"
    },
    {
      "text": "湛呵！似或存。"
    },
    {
      "text": "吾不知誰之子，象帝之先。"
    }
  ],
  "sections": {},
  "annotations": [],
  "layers": {
    "hesonggong": [
      {
        "id": "hesonggong-1",
