  "genre": "prose",
  "verses": [
    {
      "text": "上善若水。水善利萬物而不爭，處眾人之所惡，故幾於道。"
    },
    {
      "text": "居善地，心善淵，與善仁，言善信，正善治，事善能，動善時。"
    },
    {
      "text": "夫唯不爭，故無尤。"
    }
  ],
