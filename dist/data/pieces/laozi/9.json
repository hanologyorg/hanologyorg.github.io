  "genre": "prose",
  "verses": [
    {
      "text": "持而盈之，不如其已。"
    },
    {
      "text": "揣而銳之，不可長保。"
    },
    {
      "text": "金玉滿堂，莫之能守。"
    },
    {
      "text": "富貴而驕，自遺其咎。"
    },
    {
      "text": "功遂身退，天之道也。"
    }
  ],
