          "scope": "verse",
          "verseIndex": 2,
          "start": 0,
          "end": 31
        },
        "kind": "semantic",
        "text": "貴大患若身，言身為患本，當貴而重之，不可以穢辱。",
        "source": "cham"
      },
      {
        "id": "hesonggong-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 27
        },
        "kind": "semantic",
        "text": "貴身愛身，可以寄託天下，為天下主。",
        "source": "cham"
      }
    ],
