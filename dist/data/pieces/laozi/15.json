          "end": 17
        },
        "kind": "semantic",
        "text": "古之善為士者，深不可識，故其容貌若豫若猶若儼，如冬涉川，如畏四鄰，如客自持。",
        "source": "cham"
      },
      {
        "id": "wangbi-2",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 3,
          "start": 0,
          "end": 14
        },
        "kind": "semantic",
        "text": "渙若冰釋，敦若樸素，曠若空谷，混若濁水。",
        "source": "cham"
      },
      {
        "id": "wangbi-3",
        "range": {
          "type": "range",
          "scope": "verse",
          "verseIndex": 5,
          "start": 0,
          "end": 19
        },
        "kind": "semantic",
        "text": "能使濁者清，安者動，保此道者不欲盈滿，故能蔽不新成。",
        "source": "cham"
      }
    ]
