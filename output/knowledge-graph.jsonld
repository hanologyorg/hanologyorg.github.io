    {
      "@id": "poem:26",
      "@type": "CreativeWork",
      "name": "山中送別",
      "author": "author:%E7%8E%8B%E7%B6%AD",
      "position": 26,
      "text": "山中相送罷，日暮掩柴扉。\n春草明年綠，王孫歸不歸？",
