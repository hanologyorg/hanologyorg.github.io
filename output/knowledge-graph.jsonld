    {
      "@id": "poem:74",
      "@type": "CreativeWork",
      "name": "元日",
      "author": "author:%E7%8E%8B%E5%AE%89%E7%9F%B3",
      "position": 74,
      "text": "爆竹聲中一歲除，\n春風送暖入屠蘇。\n千門萬戶曈曈日，\n總把新桃換舊符。",
